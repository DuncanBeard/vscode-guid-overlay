{
  "name": "guid-visual-overlay",
  "displayName": "GUID Visual Overlay",
  "description": "Deterministic visual identity overlay for GUIDs/UUIDs",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "guid-visual-overlay.insertGuid",
        "title": "Insert GUID"
      }
    ],
    "keybindings": [
      {
        "command": "guid-visual-overlay.insertGuid",
        "key": "ctrl+k ctrl+alt+shift+g"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "jdenticon": "^3.3.0"
  }
}
