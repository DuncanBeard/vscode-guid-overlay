{
  "name": "guid-visual-overlay",
  "displayName": "GUID Visual Overlay",
  "description": "Deterministic visual identity overlay for GUIDs/UUIDs",
  "version": "1.0.3",
  "publisher": "duncanbeard",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DuncanBeard/vscode-guid-overlay.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "guid-visual-overlay.insertGuid",
        "title": "Insert GUID"
      },
      {
        "command": "guid-visual-overlay.lookupGuidAtCursor",
        "title": "GUID: Look up in Azure AD"
      },
      {
        "command": "guid-visual-overlay.clearAadCache",
        "title": "GUID: Clear Azure AD Cache"
      }
    ],
    "keybindings": [
      {
        "command": "guid-visual-overlay.insertGuid",
        "key": "ctrl+k ctrl+alt+shift+g"
      }
    ],
    "configuration": {
      "title": "GUID Visual Overlay",
      "properties": {
        "guidVisualOverlay.avatarStyle": {
          "type": "string",
          "default": "bottts",
          "enum": [
            "adventurer",
            "adventurerNeutral",
            "avataaars",
            "avataaarsNeutral",
            "bigEars",
            "bigEarsNeutral",
            "bigSmile",
            "bottts",
            "croodles",
            "croodlesNeutral",
            "dylan",
            "lorelei",
            "loreleiNeutral",
            "micah",
            "notionists",
            "notionistsNeutral",
            "openPeeps",
            "personas"
          ],
          "enumDescriptions": [
            "Adventurer - Illustrated adventure characters",
            "Adventurer Neutral - Adventurer with neutral expressions",
            "Avataaars - Cartoon people (like Slack avatars)",
            "Avataaars Neutral - Avataaars with neutral expressions",
            "Big Ears - Cute characters with big ears",
            "Big Ears Neutral - Big Ears with neutral expressions",
            "Big Smile - Happy smiling characters",
            "Bottts - Robot avatars (VS Code style)",
            "Croodles - Hand-drawn doodle characters",
            "Croodles Neutral - Croodles with neutral expressions",
            "Dylan - Stylized portrait illustrations",
            "Lorelei - Illustrated portrait style",
            "Lorelei Neutral - Lorelei with neutral expressions",
            "Micah - Modern illustrated avatars",
            "Notionists - Notion-style characters",
            "Notionists Neutral - Notionists with neutral expressions",
            "Open Peeps - Hand-drawn people illustrations",
            "Personas - Character personas"
          ],
          "description": "The avatar style to use for GUID visualization"
        },
        "guidVisualOverlay.aadLookupMode": {
          "type": "string",
          "default": "disabled",
          "enum": ["disabled", "enabled", "auto"],
          "enumDescriptions": [
            "Disabled - No Azure AD lookup functionality",
            "Enabled - Show lookup button in hover; results appear in notification",
            "Auto - Wait for Azure AD lookup before showing hover (uses timeout setting)"
          ],
          "description": "Azure AD lookup mode. Requires Azure CLI (az) to be installed and authenticated."
        },
        "guidVisualOverlay.aadLookupTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "Timeout in milliseconds for Azure AD operations. In 'auto' mode, the hover will wait up to this duration for AAD lookup results. This timeout also applies to Azure CLI (az) availability checks used in all modes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc --noEmit && bun run build.ts --minify",
    "build": "bun run build.ts",
    "compile": "bun run build.ts",
    "watch": "bun --watch build.ts",
    "test": "tsc --noEmit && bun test src/test/extension.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.1.15",
    "@types/vscode": "^1.75.0",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@dicebear/collection": "^9.3.1",
    "@dicebear/core": "^9.3.1",
    "jdenticon": "^3.3.0"
  }
}
